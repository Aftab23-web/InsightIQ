@startuml Analytics_Generation

title InsightIQ - Analytics Generation Activity Diagram

start

:User Requests Analytics;
:Parse Query Parameters;

partition "Cache Check" {
  :Generate Cache Key;
  :Check Redis Cache;
  
  if (Cache Available?) then (yes)
    if (Cache Expired?) then (yes)
      :Invalidate Cache;
    else (no)
      :Return Cached Results;
      stop
    endif
  endif
}

partition "Data Aggregation" {
  fork
    :Query Sales Metrics;
    :Calculate Revenue;
  fork again
    :Query User Metrics;
    :Calculate Engagement;
  fork again
    :Query Performance Metrics;
    :Calculate KPIs;
  end fork
  
  :Merge Results;
}

partition "Analysis" {
  :Apply Statistical Models;
  :Calculate Trends;
  :Generate Predictions;
  :Identify Patterns;
  :Calculate Percentiles;
}

partition "Visualization" {
  :Generate Chart Data;
  :Format for Frontend;
  fork
    :Create Line Charts;
  fork again
    :Create Bar Charts;
  fork again
    :Create Pie Charts;
  fork again
    :Create Heatmaps;
  end fork
}

partition "Caching" {
  :Serialize Results;
  :Store in Redis;
  :Set Expiration Time;
}

:Return Analytics Response;

stop

@enduml